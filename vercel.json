{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)\\.(jsx|css)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=300, s-maxage=300" }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/worker/dispatch-queue",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/cron/manager-inactivity",
      "schedule": "0 9 * * *"
    }
  ]
}
