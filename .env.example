# koino-insurance-os — environment variables
#
# Copy to .env (gitignored) for local Edge / Node runtime, or set in the Vercel
# dashboard for deploy. The browser bundle has no build step; runtime injection
# for browser-side values goes through `window.__ENV` (see lib/supabase-config.js).

# ── Supabase ──────────────────────────────────────────────────────────────────
# Public-tier values. Safe to ship to the browser; protected by RLS.
# Used by /api/* Edge functions via process.env (NEXT_PUBLIC_ prefix is the
# Vercel/Next convention this project already uses across api/*.js).
NEXT_PUBLIC_SUPABASE_URL=https://jfphwmzwteermalzwojp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_cOWY-O9gg5-jPbxnIta4AA_qzogKrSr

# Server-only. Bypasses RLS — never expose to the browser. Required by Edge
# functions that need to write across tenants (cron sweeps, webhooks).
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Server-only. The price IDs map to the $1–5K install + retainer + per-rep
# product ladder. Webhook secret signs Stripe → /api/stripe/* callbacks.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SETUP_5000=
STRIPE_PRICE_AGENCY_MONTHLY=
STRIPE_PRICE_REP_MONTHLY=

# ── Cron auth ─────────────────────────────────────────────────────────────────
# Shared secret Vercel sends as the Authorization bearer on scheduled jobs.
CRON_SECRET=

# ── AI providers (optional) ───────────────────────────────────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# ── Demo tenant override ──────────────────────────────────────────────────────
# See lib/demo.js. Defaults to the Atlas Insurance Group seed agency_id.
DEMO_AGENCY_ID=
