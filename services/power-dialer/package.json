    "fastify": "^4.28.1",
    "@fastify/websocket": "^10.0.1",
    "livekit-server-sdk": "^2.7.2",
    "pino": "^9.5.0",
    "pino-pretty": "^11.2.2",
    "twilio": "^5.3.0"
  },
  "engines": {
    "node": ">=22"
  }
