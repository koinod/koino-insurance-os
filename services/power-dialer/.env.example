# Power-dialer worker env. In dev the worker reads ../../.env.local
# from the repo root; in prod (Fly.io) these are `fly secrets set`.

# server
POWER_DIALER_PORT=9787
POWER_DIALER_HOST=0.0.0.0
POWER_DIALER_PUBLIC_URL=http://localhost:9787  # set to cloudflared tunnel URL when Twilio needs to reach you
LOG_LEVEL=info

# supabase
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_CALLER_ID=     # fallback "from" when phone_numbers pool is empty
TWILIO_RECORD=true

# livekit (self-host on mac mini by default)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=secret
LIVEKIT_SIP_TRUNK_SID=  # set after `lk sip inbound create`
LIVEKIT_SIP_DOMAIN=     # set after trunk provisioning

# sendblue (iMessage SMS lane)
SENDBLUE_API_KEY=
SENDBLUE_API_SECRET=

# compliance knobs
ABANDONMENT_HARD_STOP=0.025
CALLING_WINDOW_START=8
CALLING_WINDOW_END=21
AMD_TIMEOUT_MS=4000
